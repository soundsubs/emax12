{
    "id": "Emax_FX",
    "name": "Emax FX",
    "version": "0.1.0",
    "abbrev": "EmaxFX",
    "description": "E-mu Emax 12-bit sampling emulation: 7-pole AA filter, S/H decimation, 12-bit quantization, SSM2047-style ladder",
    "author": "soundsubs",
    "dsp": "Emax_FX.so",
    "api_version": 2,
    "capabilities": {
        "audio_in": true,
        "audio_out": true,
        "chainable": true,
        "component_type": "audio_fx",
        "capture": {
            "groups": ["pads"]
        },
        "chain_params": [
            {
                "key": "rate",
                "name": "Sample Rate",
                "type": "enum",
                "options": ["10kHz", "20kHz", "28kHz", "42kHz"],
                "default": "10kHz",
                "options_as_string": true
            },
            {
                "key": "ladder_cutoff",
                "name": "Ladder Cutoff",
                "type": "float",
                "min": 200,
                "max": 12000,
                "step": 10,
                "default": 8000,
                "unit": "Hz"
            },
            {
                "key": "ladder_resonance",
                "name": "Ladder Resonance",
                "type": "float",
                "min": 0,
                "max": 0.98,
                "step": 0.01,
                "default": 0.2
            },
            {
                "key": "ladder_bypass",
                "name": "Ladder Bypass",
                "type": "enum",
                "options": ["Off", "On"],
                "default": "Off",
                "options_as_string": true
            }
        ]
    }
}
