{
    "id": "Emax_FX",
    "name": "Emax FX",
    "version": "0.4.2",
    "abbrev": "EmaxFX",
    "description": "E-mu Emax 12-bit sampling emulation: 7-pole AA filter, S/H decimation, 12-bit quantization, SSM2047-style ladder",
    "author": "soundsubs",
    "license": "MIT",
    "dsp": "Emax_FX.so",
    "api_version": 2,
    "capabilities": {
        "chainable": true,
        "component_type": "audio_fx",
        "ui_hierarchy": {
            "levels": {
                "root": {
                    "name": "Emax FX",
                    "params": [
                        {
                            "key": "rate",
                            "label": "Rate",
                            "type": "enum",
                            "options": ["10kHz", "20kHz", "28kHz", "42kHz"],
                            "default": "10kHz"
                        },
                        {
                            "key": "ladder_cutoff",
                            "label": "Cutoff",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.901,
                            "step": 0.01,
                            "unit": "%"
                        },
                        {
                            "key": "ladder_resonance",
                            "label": "Resonance",
                            "type": "float",
                            "min": 0.0,
                            "max": 0.98,
                            "default": 0.2,
                            "step": 0.01
                        },
                        {
                            "key": "env_amount",
                            "label": "Env Mod",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.3,
                            "step": 0.01,
                            "unit": "%"
                        },
                        {
                            "key": "env_attack",
                            "label": "Attack",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.2703,
                            "step": 0.01,
                            "unit": "%"
                        },
                        {
                            "key": "env_decay",
                            "label": "Decay",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.6221,
                            "step": 0.01,
                            "unit": "%"
                        },
                        {
                            "key": "env_sustain",
                            "label": "Sustain",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.7,
                            "step": 0.01,
                            "unit": "%"
                        },
                        {
                            "key": "env_release",
                            "label": "Release",
                            "type": "float",
                            "min": 0.0,
                            "max": 1.0,
                            "default": 0.6697,
                            "step": 0.01,
                            "unit": "%"
                        }
                    ],
                    "knobs": [
                        "rate",
                        "ladder_cutoff",
                        "ladder_resonance",
                        "env_amount",
                        "env_attack",
                        "env_decay",
                        "env_sustain",
                        "env_release"
                    ]
                }
            }
        }
    }
}
